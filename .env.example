# ==============================================
# MAXEVA GESTION - Variables de Entorno
# ==============================================
# Copia este archivo como .env.local y completa los valores
# cp .env.example .env.local

# Supabase Configuration (REQUERIDO)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI Configuration (opcional, para OCR y AI Copilot)
OPENAI_API_KEY=sk-proj-xxx

# Web Push Notifications - VAPID Keys (opcional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your-email@example.com

# Deshabilitar autenticación en desarrollo (SOLO para testing local)
# IMPORTANTE: NUNCA usar en producción
# DISABLE_AUTH=true

# Amadeus API — IATA airport/city search (opcional)
# Crear cuenta gratis en https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
