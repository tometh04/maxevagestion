# ==============================================
# MAXEVA GESTION - Variables de Entorno
# ==============================================
# Copia este archivo como .env.local y completa los valores
# cp .env.example .env.local

# Supabase Configuration (REQUERIDO)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI Configuration (opcional, para OCR y AI Copilot)
OPENAI_API_KEY=sk-proj-xxx

# Web Push Notifications - VAPID Keys (opcional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your-email@example.com

# Deshabilitar autenticación en desarrollo (SOLO para testing local)
# IMPORTANTE: NUNCA usar en producción
# DISABLE_AUTH=true

# Amadeus API — IATA airport/city search (opcional)
# Crear cuenta gratis en https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Geoapify Places API — fallback para búsqueda de hoteles por destino (opcional)
# Crear cuenta gratis en https://www.geoapify.com/pricing/
GEOAPIFY_API_KEY=

# ==============================================
# Mercado Pago — Suscripciones (preapproval)
# ==============================================
# Token de producción (cobra tarjetas reales):
MERCADOPAGO_ACCESS_TOKEN=
# Secret del webhook (firma HMAC-SHA256). Configurar en panel de MP:
MERCADOPAGO_WEBHOOK_SECRET=

# Opcional: sandbox de MP para E2E testing sin cobrar tarjetas reales.
# Cuando MP_USE_SANDBOX=true, la lib usa MERCADOPAGO_ACCESS_TOKEN_SANDBOX
# en vez del token de producción. Test cards:
# https://www.mercadopago.com.ar/developers/es/docs/checkout-api/integration-test/test-cards
MERCADOPAGO_ACCESS_TOKEN_SANDBOX=
MP_USE_SANDBOX=false

# ==============================================
# Paywall / App URL
# ==============================================
# URL pública de la app, usada para back_url de MP y mailto del admin.
# DEBE incluir https:// (si falta, la normalizamos en runtime).
NEXT_PUBLIC_APP_URL=https://app.vibook.ai

# Secret compartido con Railway cron services (Bearer auth).
CRON_SECRET=

# === Vibook integrations ===
# AES-256-GCM key for encrypting webhook secrets stored in integration_webhooks table.
# Generate locally with: openssl rand -hex 32
WEBHOOK_SECRET_ENCRYPTION_KEY=

# Callbell API base URL (verify version against https://dev.callbell.eu/)
CALLBELL_API_BASE_URL=https://api.callbell.eu/v1.1
