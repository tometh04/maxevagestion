# =============================================================================
# VIBOOK — Staging Environment Variables
# =============================================================================
# Copy this file to .env.staging and fill in the staging-specific values.
# DO NOT commit .env.staging to git.
#
# Absolute path: /Users/tomiisanchezz/Desktop/Repos/erplozada/.env.staging.example
# =============================================================================

# -----------------------------------------------------------------------------
# STAGING-SPECIFIC: Supabase (vibook-staging project)
# Get these from: https://supabase.com/dashboard/project/<staging-project-id>/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<staging-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# Used by Supabase CLI / migrations (not needed for runtime, but handy):
SUPABASE_DB_PASSWORD=<staging-db-password>

# -----------------------------------------------------------------------------
# STAGING-SPECIFIC: App URL
# Set to your Railway staging service URL (or localhost for local dev)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://vibook-staging.up.railway.app

# -----------------------------------------------------------------------------
# DECIDE PER SERVICE: reuse prod values OR use sandbox/test credentials
# -----------------------------------------------------------------------------

# MercadoPago — use MP sandbox credentials for staging (avoids real charges)
# Get from: https://www.mercadopago.com.ar/developers/panel/app
# RECOMENDATION: USE SANDBOX KEYS HERE — NOT PROD KEYS
MP_ACCESS_TOKEN=TEST-<sandbox-mp-access-token>
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-<sandbox-mp-public-key>

# Resend (email) — you can reuse prod key or create a free staging API key
# Using prod key in staging means real emails go out — decide accordingly
RESEND_API_KEY=re_<staging-or-prod-resend-key>

# OpenAI — safe to reuse prod key (billing is per-token, no sandbox needed)
OPENAI_API_KEY=sk-<openai-key>

# AFIP — use AFIP homologación (testing) environment for staging
# AFIP_ENV should be 'homologacion' for staging, 'produccion' for prod
AFIP_ENV=homologacion
AFIP_CUIT=<test-cuit-for-homologacion>

# Callbell / WhatsApp — use a test inbox or sandbox if available
# Otherwise leave blank — WA features will be disabled in staging
CALLBELL_API_KEY=<staging-callbell-key-or-leave-blank>
CALLBELL_CHANNEL_UUID=<staging-channel-uuid-or-leave-blank>

# Cron security secret — MUST be different from prod
# Generate with: openssl rand -hex 32
CRON_SECRET=<generate-new-random-hex-64-chars>

# Internal API secret (if used)
API_SECRET=<generate-new-random-hex-32-chars>

# Railway / deployment
RAILWAY_ENVIRONMENT=staging

# -----------------------------------------------------------------------------
# SAME AS PROD: Copy these verbatim from your prod .env
# (no staging-specific value needed)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=...        (analytics — staging traffic pollutes prod)
# NEXT_PUBLIC_POSTHOG_HOST=...       (consider a separate staging project in PostHog)
# DATABASE_URL=...                   (NOT needed — Supabase URL covers this)
